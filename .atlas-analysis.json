  "keyFeatures": [
    "SPDM 1.0–1.4 Requester and Responder implementation",
    "Secure session establishment via KEY_EXCHANGE and PSK_EXCHANGE",
    "Device attestation via GET_MEASUREMENTS and CHALLENGE",
    "Multiple transport bindings: MCTP, PCI DOE, Storage, TCP",
    "Traditional and post-quantum cryptography (ML-DSA, SLH-DSA, ML-KEM)",
    "FIPS 140-3 cryptographic algorithm self-test support",
    "Zero dynamic memory allocation — suitable for embedded environments",
    "OpenSSL and Mbed TLS cryptography backends",
    "Multi-architecture support: x64, ia32, ARM, AArch64, RISC-V"
  ],
  "publicApiSurface": [
    "libspdm_init_context",
    "libspdm_deinit_context",
    "libspdm_set_data / libspdm_get_data",
    "libspdm_register_device_io_func",
    "libspdm_register_transport_layer_func",
    "libspdm_register_device_buffer_func",
    "libspdm_init_connection",
    "libspdm_get_digest",
    "libspdm_get_certificate",
    "libspdm_challenge",
    "libspdm_get_measurement",
    "libspdm_start_session",
    "libspdm_stop_session",
    "libspdm_heartbeat",
    "libspdm_key_update",
    "libspdm_get_csr",
    "libspdm_set_certificate",
    "libspdm_responder_dispatch_message",
    "libspdm_register_get_response_func",
    "libspdm_init_msg_log / libspdm_set_msg_log_mode"
  ]
